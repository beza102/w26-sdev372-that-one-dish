# Build the frontend first
FROM node:22-alpine AS build-stage
WORKDIR /frontend
COPY ../frontend/package*.json ./
RUN npm install
COPY ../frontend ./
RUN npm run build

# Use Node.js base image
FROM node:22-alpine

WORKDIR /app

# Copy package files and install dependencies
COPY package*.json ./
RUN npm install

# Copy backend code
COPY . .

# Copy the built frontend into the backend's dist folder
COPY --from=build-stage /frontend/dist ./dist

# Create uploads folder
RUN mkdir -p uploads

# Expose backend port
EXPOSE 3000

# Start the backend
CMD ["npm", "start"]